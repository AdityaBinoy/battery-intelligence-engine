function simulateBattery()
{
const cells = [

(3.8 + Math.random()*0.4),
(3.8 + Math.random()*0.4),
(3.8 + Math.random()*0.4),
(3.8 + Math.random()*0.4)

];

document.getElementById("c1").innerHTML=cells[0].toFixed(2)+" V";
document.getElementById("c2").innerHTML=cells[1].toFixed(2)+" V";
document.getElementById("c3").innerHTML=cells[2].toFixed(2)+" V";
document.getElementById("c4").innerHTML=cells[3].toFixed(2)+" V";

const avg =
cells.reduce((a,b)=>a+b,0)/4;

const max=Math.max(...cells);
const min=Math.min(...cells);

const imbalance=
((max-min)/avg)*100;

const strongest=
cells.indexOf(max)+1;

const weakest=
cells.indexOf(min)+1;

let status="";
let css="";

if(imbalance<2)
{
status="Healthy";
css="healthy";
}
else if(imbalance<5)
{
status="Minor Imbalance";
css="minor";
}
else if(imbalance<10)
{
status="Critical Imbalance";
css="critical";
}
else
{
status="Pack Failure";
css="failure";
}

document.getElementById("avg").innerHTML=
avg.toFixed(2)+" V";

document.getElementById("imbalance").innerHTML=
imbalance.toFixed(2)+" %";

document.getElementById("strongest").innerHTML=
"Cell "+strongest;

document.getElementById("weakest").innerHTML=
"Cell "+weakest;

document.getElementById("status").innerHTML=
`<span class="${css}">${status}</span>`;
}

simulateBattery();

setInterval(simulateBattery,1000);
# Adaptive Multi-Cell Battery Intelligence Engine

## Overview

This project implements a battery intelligence engine capable of monitoring a simulated 4-cell lithium-ion battery pack in real time.

## Features

- Individual cell voltage monitoring
- Pack average voltage calculation
- Cell imbalance detection
- Strongest and weakest cell identification
- Battery health classification
- Real-time dashboard updates

## Health States

Healthy
Minor Imbalance
Critical Imbalance
Pack Failure

## Formulae

Average Voltage:

Vavg = (V1+V2+V3+V4)/4

Imbalance Percentage:

((Vmax-Vmin)/Vavg)×100

